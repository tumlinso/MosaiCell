@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(CellShard REQUIRED COMPONENTS runtime)
find_dependency(CUDAToolkit REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/CellShardPreprocessTargets.cmake")

if(TARGET CellShardPreprocess::preprocess AND TARGET Cellerator::dist)
    target_link_libraries(CellShardPreprocess::preprocess INTERFACE Cellerator::dist)
endif()

check_required_components(CellShardPreprocess)
